{
  "name": "kwanwing.hk",
  "description": "Kwanwing.hk Nuxt 4",
  "version": "1.0.0",
  "author": "ken <kenchanjp2024@gmail.com>",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "wrangler pages dev .output/public",
    "deploy": "bun run build && bun run generate-cv && wrangler pages deploy .output/public",
    "generate-cv": "bun run scripts/generate-cv.ts",
    "watch-cv": "bun run scripts/watch-cv.ts",
    "postinstall": "nuxt prepare",
    "cleandev": "rm -rf .nuxt && rm -rf node_modules && bun install && bun run dev"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.9",
    "@nuxt/icon": "^1.1.0",
    "@nuxtjs/i18n": "^8.3.1",
    "@vueuse/core": "^10.9.0",
    "nuxt": "3.15.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@iconify-json/ic": "^1.2.4",
    "@tailwindcss/vite": "^4.0.0",
    "sass": "^1.72.0",
    "wrangler": "^4.74.0"
  }
}