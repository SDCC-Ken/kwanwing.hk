{
  "name": "kwanwing.me",
  "description": "Kwanwing.me Nuxt 4",
  "version": "1.0.0",
  "author": "ken <kenchanjp2024@gmail.com>",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "wrangler pages dev .output/public",
    "deploy": "bun run build && bun run generate-cv && wrangler pages deploy dist",
    "generate-cv": "bun run scripts/generate-cv.ts",
    "watch-cv": "bun run scripts/watch-cv.ts",
    "postinstall": "nuxt prepare",
    "cleandev": "rm -rf .nuxt .output node_modules;bun install;bun run dev;"
  },
  "dependencies": {
    "@floating-ui/vue": "^1.1.11",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/i18n": "^10.2.3",
    "@vueuse/core": "^14.2.1",
    "nuxt": "^4.4.2",
    "playwright": "^1.58.2",
    "unhead": "^2.1.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/ic": "^1.2.4",
    "@tailwindcss/vite": "^4.2.2",
    "wrangler": "^4.76.0"
  }
}